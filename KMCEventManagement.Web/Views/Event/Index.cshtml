@model List<KMCEventManagement.Web.Models.Event>

@{
    ViewData["Title"] = "Events";
}

<div class="container mt-4">

    <h2 class="text-primary mb-4">
        Upcoming Events
    </h2>

    <div class="row">

        @foreach (var item in Model)
        {
            <div class="col-md-4">

                <div class="card shadow mb-4">

                    <div class="card-body">

                        <h4>@item.Title</h4>

                        <p>@item.Description</p>

                        <p>
                            <strong>Category:</strong>
                            @item.Category
                        </p>

                        <p>
                            <strong>Location:</strong>
                            @item.Location
                        </p>

                        <p>
                            <strong>Date:</strong>
                            @item.EventDate.ToString("dd MMM yyyy")
                        </p>

                        <a asp-controller="Event"
                           asp-action="Details"
                           asp-route-id="1"
                           class="btn btn-primary">
                            View Details
                        </a>

                    </div>

                </div>

            </div>
        }

    </div>

</div>